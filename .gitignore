# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg
*.egg-info/
dist/
build/
*.so

# Virtual Environment
venv/
.env/
env/
ENV/

# Jupyter
.ipynb_checkpoints/
*.ipynb_checkpoints

# Data (raw data not committed — too large)
data/raw/*.csv
data/raw/*.zip
data/raw/*.json

# Cleaned data — commit only small samples
# data/cleaned/  ← uncomment to ignore cleaned too
# Large datasets
data/cleaned/*.csv
data/cleaned/*.xlsx

# IDE
.vscode/settings.json
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db
desktop.ini

# Logs
*.log
logs/

# Environment variables
.env
.env.local

# Reports (regenerate from code)
reports/*.pdf

# Power BI (binary, version-control unfriendly — commit selectively)
dashboard/*.pbix

# Images generated by code (commit selectively)
# images/

# Pytest / Coverage
.pytest_cache/
.coverage
htmlcov/
